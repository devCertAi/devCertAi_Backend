# ─── Database ────────────────────────────────────────────────────────────────

DATABASE_URL=#supabase

DIRECT_URL=#supabase



# ─── Redis (Upstash free tier) ───────────────────────────────────────────────
# REDIS_URL=
# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_DIFFERENT_RANDOM_64_CHARS
# ─── AI Provider ─────────────────────────────────────────────────────────────

AI_PROVIDER=mistral

# Only the key matching your AI_PROVIDER is required
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── GitHub (for repo analysis) ──────────────────────────────────────────────
# Create at: https://github.com/settings/tokens (no scope needed for public repos)
GITHUB_TOKEN=

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ─── Cloudinary (file storage + certificate hosting) ─────────────────────────
# Free at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Gmail SMTP (transactional emails) ───────────────────────────────────────
# Use App Password (not your real password): myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_PASS=

# ─── Razorpay (payments) ─────────────────────────────────────────────────────
# Test keys at: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

PYTHON_PIPELINE_URL=http://127.0.0.1:8001
